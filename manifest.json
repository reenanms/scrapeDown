{
  "manifest_version": 3,
  "name": "ScrapeDown",
  "version": "1.0.4",
  "description": "A configurable extension to scrape book content from web pages.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "ScrapeDown",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "32": "src/icons/icon32.png",
      "48": "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "32": "src/icons/icon32.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/vendor/turndown.js",
        "dist/content.js"
      ],
      "run_at": "document_end"
    }
  ]
}